# ─────────────────────────────────────────────────────────────────────────────
# SecureVault — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — add it to .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_a_long_random_string

# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-secret-key-here

# Supabase Dashboard → Project Settings → Database → Session pooler URI
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Set to true for local development only. Leave unset or false in production.
DEBUG=false
